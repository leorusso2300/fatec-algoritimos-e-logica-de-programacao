// Data atual  : 12/03/2026
// Seçăo de Declaraçőes das variáveis 
RAIO: REAL
PERIMETRO: REAL

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 

Pi<-3,1416

ESCREVAL("DIGITE O VALOR DO RAIO")
LEIA(RAIO)
PERIMETRO<-(2*Pi*RAIO)

ESCREVAL("PERIMETRO=",PERIMETRO)


Fimalgoritmo