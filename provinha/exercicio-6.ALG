Algoritmo "Exercicio - 6"
// Descriçăo   : Calcula o valor de duas expressőes matemáticas.
// Autor(a)    : Leonardo Russo
// Data atual  : 12/03/2026

Var
resultado1, resultado2: inteiro

Inicio

resultado1 <- ((4 * 8) + 3) * 7
resultado2 <- ((12 - 5) * (-4)) + (3 * (-2))

escreval("Resultado da primeira expressăo: ", resultado1)
escreval("Resultado da segunda expressăo: ", resultado2)

Fimalgoritmo