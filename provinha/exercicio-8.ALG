Algoritmo "Leonardo Russo"
// Descrição   : Exercício 8 - Conversão de Fahrenheit para Celsius
// Autor(a)    : Leonardo Russo
// Data atual  : 12/03/2026

Var
   farenheit, celsius: real

Inicio

   escreva("Digite a temperatura em Fahrenheit: ")
   leia(farenheit)

   celsius <- (farenheit - 32) * 5 / 9

   escreva("Temperatura em Celsius: ", celsius)

Fimalgoritmo